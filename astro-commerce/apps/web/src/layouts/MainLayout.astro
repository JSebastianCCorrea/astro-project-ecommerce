---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "Astro Ecommerce - Demo/template pagina web"
} = Astro.Props;

---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name=" viewport" content="width=device=width, intial-scale=1.0" />
        <meta name="description" content={description} />
        <title>{title}</title>
    </head>
    <body>
        <Header />
        <main>
            <slot />
        </main>
        <Footer />
    </body>
</html>
